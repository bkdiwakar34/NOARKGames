; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="NOARKGames"
run/main_scene="uid://vhx3bkgoif43"
config/features=PackedStringArray("4.5", "Forward Plus")
boot_splash/bg_color=Color(1, 1, 1, 1)
boot_splash/fullsize=false
boot_splash/image="uid://dliw4qk8oe66i"
config/icon="res://icon.svg"
boot_splash/minimum_display_time=2000

[autoload]

PatientDB="*res://Main_screen/Scripts/patient_db.gd"
Manager="*res://Main_screen/Scripts/manager.gd"
GlobalSignals="*res://Main_screen/Scripts/global_signals.gd"
GlobalScript="*res://Main_screen/Scripts/global_script.gd"
SoundFx="*res://Main_screen/Scenes/SoundFx.tscn"
GlobalTimer="*res://Main_screen/Scripts/global_timer.gd"
ScoreManager="*res://Main_screen/Scripts/score_db.gd"
DebugSettings="*res://Main_screen/Scripts/debug_settings.gd"
AudioManager="*res://Games/Jumpify/Scenes/Managers/AudioManager.tscn"
SceneTransition="*res://Games/Jumpify/Scenes/Managers/SceneTransition.tscn"
GlobalTimerManager="*res://Main_screen/Scripts/GlobalTimerManager.gd"
MusicManager="*res://Main_screen/Scripts/MusicManager.gd"
ButtonSoundManager="*res://Main_screen/Scripts/btn_sound_manager.gd"
CircularTimer="*res://Games/random_reach/scenes/circular_timer.gd"

[display]

window/size/mode=2
window/stretch/mode="canvas_items"
window/stretch/aspect="ignore"

[dotnet]

project/assembly_name="Oskar Game v2"

[editor]

version_control/autoload_on_startup=true

[editor_plugins]

enabled=PackedStringArray("res://addons/easy_charts/plugin.cfg")

[filesystem]

import/blender/enabled=false

